# =============================================
# HERALD — Environment Variables (example)
# Copy this file to .env.local and fill in real values.
# Secrets marked "fetched via 1Claw at runtime" are pushed into the vault by
# `npm run seed:vault` — the running agent never reads them from process.env.
# =============================================

# 1Claw — Agent identity (used to pull vault secrets at runtime)
# Sign up at 1claw.dev, create a vault, and generate an agent token.
ONECLAW_AGENT_ID=
ONECLAW_AGENT_API_KEY=
ONECLAW_VAULT_ID=
ONECLAW_BASE_URL=https://api.1claw.xyz

# Circle — stored here because the Circle SDK needs it for wallet creation scripts
# (npm run provision:wallet). The agent itself reads it via the 1Claw vault at runtime.
CIRCLE_API_KEY=

# Herald Agent Wallet — populated after: npm run provision:wallet
HERALD_WALLET_ID=
HERALD_WALLET_ADDRESS=
CIRCLE_ENTITY_SECRET=

# Sources Treasury Wallet — a SEPARATE wallet the agent pays real x402
# nanopayments to when it reads HERALD's own gated original content
# (src/server/routes/sources.ts). Populated after: npm run provision:sources-wallet
HERALD_SOURCES_WALLET_ID=
HERALD_SOURCES_WALLET_ADDRESS=

# Gemini API Key — used for brief synthesis (see synthesize.ts).
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Arc Testnet chain config — REQUIRED for real x402 payments (buy + sell side).
# NETWORK matches Circle's own "blockchain" field casing (ARC-TESTNET).
# USDC_ARC_TESTNET_ADDRESS is the ERC20 USDC contract (6 decimals) — the one
# EIP-3009/x402 transferWithAuthorization actually operates on. Arc's *native*
# gas-token USDC balance (isNative: true, 18 decimals) has no contract address
# and cannot be used for x402 signing.
NETWORK=ARC-TESTNET
USDC_ARC_TESTNET_ADDRESS=0x3600000000000000000000000000000000000000

# Server config
HERALD_API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NODE_ENV=development
